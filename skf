#!/usr/bin/env bash
# skf — fuzzy-find an agent "skill" by name OR description.
#
# Agent-agnostic: scans SKILL.md files across Claude Code, Codex, OpenCode, Pi,
# and any custom roots. Read-only — never modifies skills, so manual invocation
# stays intact. The picker prints the skill's invocation token (default "/<name>")
# and copies it to the clipboard so you can paste it into your agent.
#
# Usage:
#   skf                 interactive fzf picker
#   skf <term>          picker pre-seeded with <term>
#   skf -p [<term>]     print mode (no UI): list matches; TUI-safe via `! skf -p ...`
#   skf -h              show this help
#
# Config (env vars):
#   SKF_PATHS    colon-separated extra roots to scan (highest priority)
#   SKF_PREFIX   invocation prefix to print/copy (default "/")
#
# Requirements: bash, fzf (interactive mode), awk.
# Clipboard optional: pbcopy / xclip / xsel / wl-copy / clip.exe.
set -euo pipefail

PREFIX="${SKF_PREFIX-/}"

# --- search_roots: emit dirs to scan, highest priority first (custom > project > global) ---
search_roots() {
  [ -n "${SKF_PATHS:-}" ] && printf '%s\n' "$SKF_PATHS" | tr ':' '\n'
  local proj d
  proj=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
  for d in .claude .codex .opencode .pi .skills; do
    [ -d "$proj/$d" ] && printf '%s\n' "$proj/$d"
  done
  for d in "$HOME/.claude" "$HOME/.codex" "$HOME/.config/opencode" "$HOME/.opencode" "$HOME/.pi" "$HOME/.config/pi"; do
    [ -d "$d" ] && printf '%s\n' "$d"
  done
}

# --- collect_skill_files: find SKILL.md under each root, newest version first within a root ---
collect_skill_files() {
  local root
  while IFS= read -r root; do
    find "$root" \( -name node_modules -o -name .git \) -prune -o -name SKILL.md -print 2>/dev/null | sort -rV
  done < <(search_roots)
}

# --- parse_skills: paths -> "name<TAB>desc<TAB>path", deduped by name (first wins = priority) ---
parse_skills() {
  local file
  while IFS= read -r file; do
    awk -v f="$file" '
      /^---[[:space:]]*$/ { c++; if (c>=2) exit; next }
      c!=1 { next }
      /^name:/        { v=$0; sub(/^name:[ \t]*/,"",v); n=v; next }
      /^description:/ {
        v=$0; sub(/^description:[ \t]*/,"",v)
        if (v ~ /^[>|][+-]?[[:space:]]*$/ || v=="") { collect=1; d="" } else { d=v; collect=0 }
        next
      }
      collect && /^[[:space:]]+[^[:space:]]/ {            # folded/literal block continuation
        line=$0; sub(/^[[:space:]]+/,"",line); d=(d==""?line:d" "line); next
      }
      /^[A-Za-z_][A-Za-z0-9_-]*:/ { collect=0 }           # next top-level key ends the block
      END { if (n!="") { gsub(/\t/," ",d); print n "\t" d "\t" f } }
    ' "$file"
  done | awk -F'\t' '!seen[$1]++' | sort -f
}

# --- copy_to_clipboard: pipe text to the first clipboard tool available; silent no-op if none ---
copy_to_clipboard() {
  local cmd
  for cmd in pbcopy "xclip -selection clipboard" "xsel --clipboard --input" wl-copy clip.exe; do
    command -v "${cmd%% *}" >/dev/null 2>&1 || continue
    printf '%s' "$1" | $cmd >/dev/null 2>&1 && return 0
  done
  return 1
}

# --- pick_with_fzf: fuzzy-search name+desc, preview the file, return the chosen TSV line ---
pick_with_fzf() {
  fzf --delimiter=$'\t' --with-nth=1,2 --nth=1,2 \
      --query="${1:-}" \
      --prompt='skill> ' --height=80% --layout=reverse --border \
      --preview='sed -n "1,60p" {3}' --preview-window='right:55%:wrap'
}

# --- emit_selection: print "<prefix><name>" and copy it to the clipboard ---
emit_selection() {
  local name; name=$(printf '%s' "$1" | cut -f1)
  [ -z "$name" ] && return 1
  printf '%s%s\n' "$PREFIX" "$name"
  copy_to_clipboard "$PREFIX$name" && printf '(copied to clipboard)\n' >&2 || true
}

# --- print_matches: non-interactive list; fuzzy via fzf if present, else grep substring ---
print_matches() {
  local rows; rows=$(collect_skill_files | parse_skills)
  if [ -n "$1" ]; then
    if command -v fzf >/dev/null 2>&1; then
      rows=$(printf '%s\n' "$rows" | fzf --filter="$1" --delimiter=$'\t' --with-nth=1,2 --nth=1,2 || true)
    else
      rows=$(printf '%s\n' "$rows" | grep -i -- "$1" || true)
    fi
  fi
  printf '%s\n' "$rows" | awk -F'\t' -v p="$PREFIX" 'NF{printf "%s%s  — %s\n", p, $1, substr($2,1,70)}' | head -15
}

interactive_pick() {
  command -v fzf >/dev/null 2>&1 || { echo "skf: fzf not found — install it or use 'skf -p <term>'" >&2; exit 1; }
  local choice
  choice=$(collect_skill_files | parse_skills | pick_with_fzf "${1:-}") || exit 130
  emit_selection "$choice"
}

usage() { sed -n '2,21p' "$0" | sed 's/^#\{1,2\} \{0,1\}//'; }

main() {
  case "${1:-}" in
    -h|--help) usage ;;
    -p)        shift; print_matches "${*:-}" ;;
    *)         interactive_pick "${1:-}" ;;
  esac
}

main "$@"
